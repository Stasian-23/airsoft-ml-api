# API ключи через запятую. Генерация: python scripts/generate_api_key.py
API_KEYS=your-api-key-here,another-key-if-needed

# Папка с обученными моделями
MODELS_DIR=models

# Минимальная уверенность для принятия предсказания по фото (0.0 - 1.0)
IMAGE_CONFIDENCE_THRESHOLD=0.25

# Таймаут загрузки фото по URL (секунды)
IMAGE_DOWNLOAD_TIMEOUT=10

# Максимальное количество фото в одном запросе
MAX_IMAGES_PER_REQUEST=10

# Лимит запросов (формат slowapi)
RATE_LIMIT=30/minute
